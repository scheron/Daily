{
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  "appId": "com.dailyapp.daily",
  "productName": "Daily",
  "asar": true,
  "asarUnpack": ["node_modules/@modelcontextprotocol/**/*", "node_modules/zod/**/*", "node_modules/zod-to-json-schema/**/*"],
  "copyright": "Copyright © 2025 Infected by JS",
  "directories": {
    "buildResources": "public",
    "output": "dist"
  },
  "afterPack": "scripts/afterPack-mac.js",
  "extraResources": [
    {"from": "resources/file-coordinator", "to": "file-coordinator"},
    {"from": "resources/models.json", "to": "resources/models.json"}
  ],
  "files": ["out/**/*", {"filter": ["**/*"], "from": "public", "to": "resources"}, "!dist", "!scripts", "!src", "!*.md", "!.git*", "!.DS_Store"],
  "mac": {
    "artifactName": "${productName}-${version}-mac.${ext}",
    "category": "public.app-category.productivity",
    "hardenedRuntime": true,
    "gatekeeperAssess": true,
    "identity": null,
    "icon": "icon.icns",
    "notarize": true,
    "target": [{"target": "dmg", "arch": ["arm64"]}]
  },
  "publish": null
}
